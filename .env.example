# Example configuration for lastfm-events-ical
#
# Copy this file to `.env` and adjust the values as needed.

# Contact email included in the User-Agent when scraping Last.fm (required).
CONTACT_EMAIL=you@example.com

# Last.fm username whose events are exposed (required).
LASTFM_USERNAME=your-lastfm-username

# HTTP port (default 3000).
PORT=3000

# Cache file path. Default: /data/events-cache.json
# For local dev, a relative path works: ./data/events-cache.json
CACHE_FILE_PATH=./data/events-cache.json

# Set to 1 or true to scrape on every calendar request (for development).
# When unset: serve from cache and scrape in background every 3–6 hours.
# LIVE_DATA=1

# Optional: override User-Agent for Last.fm (default uses CONTACT_EMAIL: lastfm-events-ical/1.0 (+mailto:...))
# LASTFM_SCRAPER_UA=lastfm-events-ical/1.0 (+mailto:you@example.com)

