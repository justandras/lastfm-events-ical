{
  "name": "lastfm-events-ical",
  "version": "1.0.8",
  "description": "Scrape a Last.fm user's events page and expose upcoming events as an iCalendar feed over HTTP.",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:scraper && tsc",
    "build:scraper": "npm run build --prefix packages/lastfm-scraper",
    "postinstall": "cd packages/lastfm-scraper && npm install && npm run build",
    "start": "node dist/index.js",
    "dev": "TS_NODE_PROJECT=tsconfig.test.json NODE_ENV=development ts-node-dev --respawn --transpile-only -r tsconfig-paths/register --watch packages/lastfm-scraper/src src/index.ts",
    "dev:app": "NODE_ENV=development ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p packages/lastfm-scraper/tsconfig.json",
    "check": "npm run lint && npm run typecheck"
  },
  "keywords": [
    "lastfm",
    "events",
    "ical",
    "calendar",
    "scraper",
    "typescript",
    "node"
  ],
  "author": "András Pozsgai <contact@justandras.com>",
  "license": "MIT",
  "dependencies": {
    "domhandler": "^6.0.1",
    "dotenv": "^16.5.0",
    "ics": "^3.8.1",
    "lastfm-events-scraper": "file:packages/lastfm-scraper",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.3.5",
    "eslint": "^9.23.0",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^17.5.0",
    "pino-pretty": "^13.0.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
